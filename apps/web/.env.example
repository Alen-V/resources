# --- Frontend integrations (client-side) -----------------------------
# Each integration is fully inert when its variable is unset. Set the
# value to activate; leave blank or remove the line to disable.

# Google Analytics 4 — measurement ID, e.g. G-XXXXXXXXXX
# https://support.google.com/analytics/answer/12270356
NEXT_PUBLIC_GA_ID=

# Microsoft Clarity — project ID from https://clarity.microsoft.com
NEXT_PUBLIC_CLARITY_PROJECT_ID=

# --- Server integrations (secret) ------------------------------------

# Resend API key — enables POST /api/email
# https://resend.com/api-keys
RESEND_API_KEY=

# Default "from" address used by /api/email when the request omits one.
# Must be a verified sender on your Resend account, or use Resend's
# onboarding@resend.dev for development.
RESEND_FROM_EMAIL=
