{
    "name": "resources",
    "version": "1.0.0",
    "private": true,
    "scripts": {
        "predev": "pnpm tokens:build && pnpm symbols:sync",
        "dev": "pnpm --filter web dev",
        "dev:tokens": "pnpm tokens:watch",
        "prebuild": "pnpm tokens:build && pnpm symbols:sync",
        "build": "pnpm -r build",
        "lint": "pnpm -r lint",
        "typecheck": "pnpm -r --if-present typecheck",
        "tokens:build": "pnpm --filter @monorepo/design-tokens build",
        "tokens:watch": "chokidar \"packages/design-tokens/src/**/*\" -c \"pnpm tokens:build\"",
        "symbols:meta": "node packages/icons/scripts/build-manifest.mjs",
        "symbols:sync": "node apps/web/scripts/sync-symbols.mjs",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "prepare": "husky"
    },
    "lint-staged": {
        "*.{ts,tsx,js,jsx,json,css,md,mjs,cjs}": [
            "prettier --write"
        ]
    },
    "devDependencies": {
        "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
        "chokidar-cli": "^3.0.0",
        "husky": "^9.1.7",
        "lint-staged": "^17.0.5",
        "prettier": "^3.8.3",
        "prettier-plugin-tailwindcss": "^0.8.0"
    },
    "packageManager": "pnpm@10.32.1"
}
